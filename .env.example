# ============================================================
# Playreia Auth Configuration
# Salin file ini menjadi .env dan isi dengan nilai yang benar
# ============================================================

# Database (MariaDB / MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
MYSQL_DATABASE_URL="mysql://root:password@localhost:3306/playreia"

# Auth.js Secret (wajib - generate dengan: openssl rand -hex 32)
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-hex-32"

# Google OAuth (opsional - untuk login dengan Google)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Launch Date - digunakan untuk Dynamic ID
# Format: YYYY-MM-DD
# Bulan 1 (0-30 hari): ID 8 digit
# Bulan 2 (31-60 hari): ID 9 digit
# Bulan 3+ (61+ hari): ID 10 digit
LAUNCH_DATE="2026-04-10"

# URL Produksi
CANONICAL_ORIGIN="http://localhost:5173"
